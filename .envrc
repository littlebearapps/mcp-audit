# === Keychain-based Environment Variables ===
# Source Keychain functions
[ -f ~/bin/kc.sh ] && source ~/bin/kc.sh
[ -f ~/.config/kc/profiles.sh ] && source ~/.config/kc/profiles.sh

# Load secrets from Keychain
load_mcp_secrets "mcp-audit" "main"

# Export GitHub token for gh CLI
export GITHUB_TOKEN=$(kc_get GITHUB_PAT)

# Instance identification for multi-instance coordination
export INST_ID="mcp-audit"

# Load non-secret configuration from .env
if [ -f .env ]; then
  set -a
  source .env
  set +a
fi
